# Required: Anthropic API key for LLM scoring
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Product Hunt API token (falls back to RSS without it)
PH_API_TOKEN=

# Optional: Email digest (works with Gmail, SendGrid SMTP, etc.)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=partner@fund.com,analyst@fund.com
